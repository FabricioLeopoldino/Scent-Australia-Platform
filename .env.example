# ── Platform core ─────────────────────────────────────────────────────────
# New Neon project (NOT the production SA database — see PRD §2 / guardrail #10)
PLATFORM_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# New secret — independent from SA's current JWT_SECRET (PRD OD3)
PLATFORM_JWT_SECRET=
ALLOWED_ORIGIN=
FEATURE_UPLOADS=false
NODE_ENV=development
PORT=3000

# ── Shopify — SA store (sainternalstore7811121) ──────────────────────────
SA_SHOPIFY_STORE_NAME=sainternalstore7811121
SA_SHOPIFY_ACCESS_TOKEN=
SA_SHOPIFY_WEBHOOK_SECRET=

# ── Shopify — SM (phase 1: same physical store as SA, per OD1) ───────────
SM_SHOPIFY_STORE_DOMAIN=sainternalstore7811121.myshopify.com
SM_SHOPIFY_ACCESS_TOKEN=
SM_SHOPIFY_WEBHOOK_SECRET=

# ── Migration script (scripts/migrate-sa.js, Phase 2a) ───────────────────
# Read-only source: the LIVE SA production database. Used only by the
# migration script — the server never connects to it.
SA_SOURCE_DATABASE_URL=
